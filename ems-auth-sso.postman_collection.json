          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/sso/callback",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "sso",
                "callback"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "not-a-real-jwt-at-all"
                },
                {
                  "key": "state",
                  "value": "xyz"
                }
              ]
            },
            "description": ""
          },
          "response": []
        }
      ]
