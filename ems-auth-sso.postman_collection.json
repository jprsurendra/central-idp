    {
      "name": "03 \u2014 Pattern A Callback (/sso/callback)",
      "item": [
        {
          "name": "STEP 1 \u2014 Log in on central-idp directly, capture the assertion token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 302 (redirect with token)', () => pm.response.to.have.status(302));",
                  "pm.test('Location header contains a token \u2014 capture it for Step 2', () => {",
                  "    const location = pm.response.headers.get('Location');",
                  "    pm.expect(location).to.include('token=');",
                  "    const tokenMatch = location.match(/token=([^&]+)/);",
                  "    pm.collectionVariables.set('capturedAssertionToken', decodeURIComponent(tokenMatch[1]));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{centralIdpBaseUrl}}/api/v1/identity/authorize",
              "host": [
                "{{centralIdpBaseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "identity",
                "authorize"
              ]
            },
            "description": "This is central-idp's own endpoint, called directly here (not through the Gateway) purely to obtain a real assertion token for Step 2, simulating what a browser would receive after the user submits the login form.",
            "body": {
              "mode": "raw",
              "raw": "username={{existingCentralIdpUsername}}&password={{existingCentralIdpPassword}}&redirectUri={{redirectUri}}&state=postman-chain",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "protocolProfileBehavior": {
            "followRedirects": false
          }
        },
        {
          "name": "STEP 2 \u2014 Present the token to ems-auth's callback \u2014 200 with RajSahay JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains a real JWT', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.accessToken.split('.').length).to.eql(3);",
                  "    pm.expect(json.tokenType).to.eql('Bearer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/sso/callback",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "sso",
                "callback"
              ],
              "query": [
                {
                  "key": "token",
                  "value": "{{capturedAssertionToken}}"
                },
                {
                  "key": "state",
                  "value": "postman-chain"
                }
              ]
            },
            "description": "Run Step 1 immediately before this in the same run, so capturedAssertionToken is populated. This two-step chain exercises the exact same validation path (signature, issuer, audience) a real browser redirect would, without needing an actual browser."
          },
          "response": []
        },
        {
          "name": "Missing token parameter \u2014 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400 (missing required parameter)', () => {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/sso/callback",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "sso",
                "callback"
              ],
              "query": [
