    {
      "name": "01 \u2014 Registration Proxy (/register/sso)",
      "item": [
        {
          "name": "Happy path \u2014 proxies to central-idp, auto-login \u2014 200 with JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response contains a real JWT', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.accessToken.split('.').length).to.eql(3);",
                  "    pm.expect(json.tokenType).to.eql('Bearer');",
                  "    pm.collectionVariables.set('capturedRajSahayJwt', json.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register/sso",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register",
                "sso"
              ]
            },
            "description": "Calls central-idp's /register internally, then creates a linked local profile row in the same request, then issues a RajSahay JWT immediately.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"emsauth_test_{{$timestamp}}\",\n  \"password\": \"Test@1234\",\n  \"fullName\": \"EMS Auth Test User\",\n  \"email\": \"emsauth_test_{{$timestamp}}@example.com\",\n  \"department\": \"QA\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
