                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/identity/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "identity",
                "register"
              ]
            },
            "description": "Plain, non-dynamic example \u2014 safe to copy/paste manually into a new request. Will return 409 on every run after the first, since 'newuser1' won't be unique a second time. Use the 'Happy path' request below for repeatable automated runs.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser1\",\n  \"password\": \"Test@1234\",\n  \"fullName\": \"New User One\",\n  \"email\": \"newuser1@example.com\",\n  \"department\": \"MSME Services\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Happy path \u2014 new user registers successfully \u2014 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response contains a real externalId (UUID shape)', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.externalId).to.match(/^[0-9a-f-]{36}$/i);",
                  "    pm.collectionVariables.set('registeredUsername', json.username);",
                  "    pm.collectionVariables.set('registeredExternalId', json.externalId);",
                  "});",
                  "pm.test('Password is never echoed back', () => {",
                  "    pm.expect(pm.response.text()).to.not.include('Test@1234');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
