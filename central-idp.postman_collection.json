          "name": "EXAMPLE \u2014 Plain static request body (for manual reference/copy)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 on first run, or 409 if newuser1 already exists', () => {",
