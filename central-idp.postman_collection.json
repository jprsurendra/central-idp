                  "    const location = pm.response.headers.get('Location');",
                  "    pm.expect(location).to.include('token=');",
                  "    pm.expect(location).to.include('state=xyz123');",
                  "    const tokenMatch = location.match(/token=([^&]+)/);",
                  "    if (tokenMatch) {",
                  "        pm.collectionVariables.set('capturedToken', decodeURIComponent(tokenMatch[1]));",
                  "    }",
                  "});",
                  "pm.test('Captured token looks like a JWT (three dot-separated segments)', () => {",
                  "    const token = pm.collectionVariables.get('capturedToken');",
                  "    pm.expect(token.split('.').length).to.eql(3);",
