# ==========================================
# central-idp - Environment Variables
# ==========================================
# WARNING: Do NOT commit this file to Git!
# Generate real values with: openssl rand -base64 48
# ==========================================

DB_USERNAME=root
DB_PASSWORD=change-me
DB_URL=jdbc:mysql://localhost:3306/central_idp_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

SERVER_PORT=9090

# JWT signing keys — see rotate-secrets.sh for how these get updated over time.
JWT_CURRENT_KEY_ID=key-1
JWT_CURRENT_KEY_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48_OUTPUT
JWT_PREVIOUS_KEY_ID=
JWT_PREVIOUS_KEY_SECRET=
JWT_EXPIRATION_MS=600000

# Credentials for services calling /api/v1/identity/verify (Pattern B).
# ems-auth must send these as X-Client-Id / X-Client-Secret headers.
EMS_AUTH_CLIENT_ID=ems-auth
EMS_AUTH_CLIENT_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48_OUTPUT
